[importlinter]
root_package = schedule_minion

[importlinter:contract:layers]
name = Enforce layered architecture
type = layers
layers =
    presentation
    application
    domain
    infrastructure

[importlinter:contract:independence]
name = Domain layer independence
type = forbidden
source_modules =
    schedule_minion.domain
forbidden_modules =
    schedule_minion.presentation
    schedule_minion.application
    schedule_minion.infrastructure

[importlinter:contract:no-cycles]
name = Prevent circular dependencies
type = independence
modules =
    schedule_minion
